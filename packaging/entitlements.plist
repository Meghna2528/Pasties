<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
    "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Required: allow JVM to execute arbitrary code (JIT, dynamic classloading) -->
    <key>com.apple.security.cs.allow-jit</key>
    <true/>

    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>

    <!-- Allow dynamic library loading (JNA, sqlite-jdbc native libs) -->
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>

    <!--
        Input Monitoring and Accessibility are NOT entitlements — they are
        Privacy & Security TCC permissions granted by the user at runtime.
        No plist entry is needed for them; just prompt the user via PermissionChecker.
    -->
</dict>
</plist>
